# Copiez ce fichier en .env et remplissez avec les clés de votre projet Supabase
# (Project Settings → API)

EXPO_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anon-publique

# Sur Vercel : ajoutez les mêmes variables dans Settings → Environment Variables
# (obligatoire pour le build et l'exécution web)

# Email affiché dans la politique de confidentialité (contact RGPD)
EXPO_PUBLIC_PRIVACY_CONTACT_EMAIL=brg.flora@gmail.com
